cff-version: 1.2.0
title: "snn_opt: A Spiking Neural Network Solver for Constrained Convex Optimization"
message: "If you use this software, please cite it using the metadata below."
type: software
authors:
  - family-names: "Khan"
    given-names: "Ameer Hamza"
